# Copy to .env and fill in values. The agent loads this automatically from
# the current working directory (or any parent dir) via python-dotenv.
# Variables already set in the shell win over values in this file.

# --- LLM ---
TERNO_LLM_PROVIDER=anthropic          # anthropic | openai
TERNO_LLM_MODEL=claude-opus-4-7       # optional; sensible default per provider
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Sandbox (powers the run_python tool) ---
TERNO_SANDBOX=docker                  # docker | local | none
TERNO_SANDBOX_IMAGE=python:3.12-slim  # only used for the docker sandbox

# --- MCP ---
TERNO_MCP_ENABLED=true                # set to false to skip .mcp.json entirely
# TERNO_MCP_CONFIG=/path/to/.mcp.json # overrides the default discovery
                                      # (default: ./.mcp.json then ~/.terno/mcp.json)

# --- Agent Skills ---
TERNO_SKILLS_ENABLED=true             # load built-in + SKILL.md skills
# TERNO_SKILL_PATHS=/path/to/skills   # optional extra skill roots (os path-separated)

# --- Memory (persistent recall across sessions) ---
TERNO_MEMORY_ENABLED=true             # set to false to disable recall + extraction
TERNO_MEMORY_TOP_K=5                  # how many memories to recall per turn
TERNO_EMBEDDING_PROVIDER=openai       # only 'openai' is supported today
TERNO_EMBEDDING_MODEL=text-embedding-3-small
# TERNO_EMBEDDING_API_KEY=            # defaults to OPENAI_API_KEY

# Vector store backend for memory recall.
TERNO_VECTOR_BACKEND=file             # file (local JSONL) | milvus
                                      # 'milvus' needs: pip install 'terno-agent[milvus]'
# TERNO_MILVUS_URI=./milvus.db        # local file = Milvus Lite; or http://host:19530
# TERNO_MILVUS_TOKEN=                 # user:pass or API key for a Milvus server / Zilliz
# TERNO_MILVUS_COLLECTION=terno_memory

# --- Deep research (optional — only needed for `terno deep_research`) ---
# TERNO_DATABASE_URL=sqlite:///./demo.db
# TERNO_DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
# TERNO_DATABASE_URL=mysql+pymysql://user:pass@host:3306/dbname
TERNO_MAX_ROWS=200
TERNO_READ_ONLY_SQL=true              # set to false to allow writes
